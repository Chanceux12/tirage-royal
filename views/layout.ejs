<div id="scrollRoyal">
  <svg width="70" height="70" viewBox="0 0 70 70">
    <circle class="track" cx="35" cy="35" r="30" />
    <circle class="progress" cx="35" cy="35" r="30" />
  </svg>
</div>

<style>
  #scrollRoyal {
    position: fixed;
    right: 15px;
    bottom: 15px;
    z-index: 9999;
    width: 40px;
    height: 40px;
    cursor: pointer;
    transform: rotate(-90deg); /* fait commencer le cercle en haut */
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease; /* ✅ transition fluide ajoutée */
  }

  #scrollRoyal.visible {
    opacity: 1;
    visibility: visible;
  }

  #scrollRoyal svg {
    width: 100%;
    height: 100%;
  }

  /* Cercle de fond */
  .track {
    fill: none;
    stroke: rgba(255, 255, 255, 0.1);
    stroke-width: 6;
  }

  /* Cercle de progression */
  .progress {
    fill: none;
    stroke: #f97316;
    stroke-width: 6;
    stroke-linecap: round;
    stroke-dasharray: 188.4;
    stroke-dashoffset: 188.4;
    transition: stroke-dashoffset 0.2s linear;
    filter: drop-shadow(0 0 8px #ff8c3f);
  }

  /* Lueur “royale” */
  @keyframes rotateRing {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  const progressRing = document.querySelector('.progress');
  const scrollRoyal = document.getElementById('scrollRoyal');

  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.body.scrollHeight - window.innerHeight;
    const progress = scrollTop / docHeight;
    const offset = 188.4 - progress * 188.4;

    // remplit le cercle selon le scroll
    progressRing.style.strokeDashoffset = offset;

    // fait tourner le cercle selon la progression
    scrollRoyal.style.transform = `rotate(${progress * 360 - 90}deg)`;

    // ✅ Ajout : apparition/disparition fluide
    if (scrollTop > 100) {
      scrollRoyal.classList.add('visible');
    } else {
      scrollRoyal.classList.remove('visible');
    }
  });
</script>

