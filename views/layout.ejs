<!DOCTYPE html> 
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || "Tirage Royal" %></title>

  <meta name="description" content="Tirage Royal - Plateforme de jeux de tirage en ligne. Jouez, gagnez et suivez vos résultats en toute transparence.">
  <meta name="keywords" content="tirage, loterie, jeux en ligne, tirage royal, gagner de l'argent, tirage au sort">
  <meta name="author" content="Tirage Royal">

  <link rel="icon" type="image/png" href="/image/favicon.png">
  <link rel="apple-touch-icon" href="/image/favicon.png">
  <meta name="theme-color" content="#080032">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Tirage Royal",
    "url": "https://www.tirageroyale.com",
    "logo": "https://www.tirageroyale.com/image/favicon.png"
  }
  </script>

  <meta property="og:title" content="Tirage Royal - Jeux de tirage en ligne">
  <meta property="og:description" content="Participez aux meilleurs tirages et découvrez les résultats instantanément.">
  <meta property="og:url" content="https://tirageroyale.com">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://tirageroyale.com/image/preview.png">

  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    /* ----- STYLE DU SITE EXISTANT ----- */
    body {
      margin: 0;
      font-family: "Segoe UI", Arial, sans-serif;
      background-color: #080032;
      color: #fff;
    }

    header.navbar {
      background: linear-gradient(90deg, #0e0038, #20006a);
      padding: 12px 20px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.4);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .navbar-container {
      max-width: 1300px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .navbar-left .logo {
      font-size: 1.7em;
      font-weight: 700;
      color: #fecd1a;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .navbar-left .logo:hover { color: #ffdd4a; }

    nav.navbar-menu {
      display: flex;
      gap: 15px; /* Réduit légèrement pour laisser place au bouton banque */
      align-items: center;
      flex-wrap: wrap;
    }
    nav.navbar-menu a {
      color: #fff;
      font-weight: 500;
      text-decoration: none;
      padding: 8px 12px;
      border-radius: 6px;
      transition: background-color 0.3s;
      font-size: 0.95rem;
    }
    nav.navbar-menu a:hover { background: rgba(255,255,255,0.15); }

    .dropdown-container { position: relative; display: inline-block; }
    .dropdown-btn {
      background: none;
      border: none;
      color: #fff;
      font-weight: 500;
      cursor: pointer;
      padding: 8px 12px;
      border-radius: 6px;
      transition: background 0.3s;
      font-size: 0.95rem;
    }
    .dropdown-btn:hover { background: rgba(255,255,255,0.15); }

    .dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background: #0e0038;
      min-width: 180px;
      border-radius: 6px;
      overflow: hidden;
      z-index: 1000;
      box-shadow: 0 8px 20px rgba(0,0,0,0.5);
    }
    .dropdown-menu a {
      display: block;
      padding: 10px 14px;
      color: #fff;
      text-decoration: none;
      transition: background 0.3s;
    }
    .dropdown-menu a:hover { background: rgba(255,255,255,0.15); }

    .dropdown-container:hover .dropdown-menu { display: block; }

    .navbar-right {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .navbar-right a {
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 6px;
      transition: background-color 0.3s, transform 0.3s;
      white-space: nowrap;
      text-decoration: none;
      color: #fff;
      font-size: 0.95rem;
    }
    .navbar-right a:hover { background: rgba(255,255,255,0.15); }

    .btn-orange {
      background-color: #f97316;
      padding: 8px 16px;
      border-radius: 8px;
      font-weight: 700;
      text-decoration: none;
      transition: background-color 0.3s;
      color: #fff !important;
    }
    .btn-orange:hover { background-color: #ff8c3f; }

    /* 🏦 STYLE BOUTON BPER BANCA PRO INSTITUTIONNEL */
    .btn-bper-bank {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #0c1a30 0%, #002f6c 100%);
      color: #fff !important;
      font-weight: 700 !important;
      padding: 8px 18px !important;
      border-radius: 8px;
      text-decoration: none;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
      position: relative;
      transition: all 0.3s ease;
      font-size: 0.9rem !important;
    }

    .btn-bper-bank:hover {
      background: linear-gradient(135deg, #002f6c 0%, #004094 100%);
      box-shadow: 0 6px 12px rgba(0, 71, 187, 0.4);
      transform: translateY(-2px);
    }

    .btn-bper-bank i {
      color: #00bfa5; /* Vert sécurité bancaire */
      width: 16px;
      height: 16px;
    }

    /* 🎁 ANIMATION POST-DÉCONNEXION (IMPULSION RADAR DORÉE) */
    @keyframes radarPulse {
      0% { box-shadow: 0 0 0 0 rgba(254, 205, 26, 0.7); }
      70% { box-shadow: 0 0 0 15px rgba(254, 205, 26, 0); }
      100% { box-shadow: 0 0 0 0 rgba(254, 205, 26, 0); }
    }

    .btn-bper-bank.animate-pulse {
      animation: radarPulse 1.5s infinite;
      border-color: #fecd1a;
    }

    /* Responsive */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: space-around;
      width: 26px;
      height: 22px;
      cursor: pointer;
      margin-left: 10px;
    }
    .hamburger span {
      width: 100%;
      height: 3px;
      background-color: white;
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }
    .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

    .mobile-menu {
      display: none;
      position: absolute;
      top: 80px; /* Ajusté selon la hauteur du logo */
      left: 0;
      right: 0;
      background-color: #0e0038;
      border-radius: 0 0 8px 8px;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
      box-shadow: 0 4px 10px rgba(0,0,0,0.5);
      z-index: 999;
    }
    .mobile-menu.open { max-height: 100vh; overflow-y: auto; padding-bottom: 20px; }
    .mobile-menu a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 20px;
      color: #fff;
      text-decoration: none;
      font-weight: 500;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .mobile-menu a:hover { background: rgba(255,255,255,0.1); }
    
    /* Bouton BPER Mobile */
    .mobile-menu .btn-bper-bank {
      margin: 15px 20px;
      justify-content: center;
      width: calc(100% - 40px);
      box-sizing: border-box;
    }

    @media (max-width: 992px){
      nav.navbar-menu { gap: 10px; }
      nav.navbar-menu a, .dropdown-btn { padding: 8px 8px; font-size: 0.85rem; }
    }

    @media (max-width: 850px){
      nav.navbar-menu, .navbar-right { display: none; }
      .hamburger { display: flex; }
      .mobile-menu { display: block; }
    }

    .logo-img {
      height: 85px;
      width: auto;
      display: block;
    }

    @media (max-width: 1024px) { .logo-img { height: 75px; } }
    @media (max-width: 768px) { .logo-img { height: 65px; } }
    @media (max-width: 480px) { .logo-img { height: 55px; } }

    /* Loader overlay */
    #loader {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      background: rgba(8,0,50,0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 99999;
      backdrop-filter: blur(5px);
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }

    /* Anneau rond animé */
    .loader-ring {
      width: 100px;
      height: 100px;
      border: 5px solid rgba(255,255,255,0.1);
      border-top: 5px solid #FFD166; /* doré */
      border-radius: 50%;
      animation: spin 1s linear infinite;
      box-shadow: 0 0 15px rgba(255, 209, 102, 0.5);
      position: relative;
    }

    /* Texte centré dans le cercle */
    .loader-text {
      position: absolute;
      color: #FFD166;
      font-size: 1.5rem;
      font-weight: 700;
      animation: pulse 1s ease-in-out infinite;
    }

    /* Animations */
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.7; transform: scale(1.1); }
    }

    /* Disparition fluide */
    body.loaded #loader {
      opacity: 0;
      visibility: hidden;
    }
  </style>
</head>

<body>
  <div id="loader">
    <div class="loader-ring"></div>
    <div class="loader-text">🎲</div>
  </div>
      

  <header class="navbar">
    <div class="navbar-container">
      <div class="navbar-left">
        <a href="/" class="logo">
          <img src="/image/logo-tirage.png" alt="Tirage Royal" class="logo-img" />
        </a>
      </div>

      <nav class="navbar-menu">
        <a href="/">Accueil</a>
        <div class="dropdown-container">
          <button class="dropdown-btn">Jeux ▼</button>
          <div class="dropdown-menu">
            <a href="/jouer">Jouer</a>
            <a href="/jeu/mes-participations">Mes tickets</a>
            <a href="/jeu/resultats">Résultats</a>
          </div>
        </div>
        <div class="dropdown-container">
          <button class="dropdown-btn">Paiements ▼</button>
          <div class="dropdown-menu">
            <a href="/paiement/retrait">Retrait</a>
            <a href="/paiement/mes-retraits">Mes retraits</a>
            <a href="/paiement/recharger">Recharger</a>
            <a href="/paiement/mes-recharges">Mes recharges</a>
          </div>
        </div>
        <a href="/contact">Contact</a>
        <% if (user) { %><a href="/profil">Mon Profil</a><% } %>
        <a href="/paiement/solde">Mon Solde</a>
      </nav>

      
      <div class="navbar-right">
        <% if(user){ %>
          <a href="https://banque-pro.vercel.app/login" target="_blank" class="btn-bper-bank" id="bperBtnDesktop">
            <i data-lucide="shield-check"></i>
            Espace Client BPER
          </a>
          <a href="/auth/logout">Déconnexion</a>
        <% } else { %>
          <a href="/auth/login" class="btn-orange">Connexion</a>
        <% } %>
      </div>



      <div class="hamburger" id="hamburger"><span></span><span></span><span></span></div>
    </div>

    <div class="mobile-menu" id="mobile-menu">
      <% if(user){ %>
        <a href="https://banque-pro.vercel.app/login" target="_blank" class="btn-bper-bank" id="bperBtnMobile">
          <i data-lucide="shield-check"></i>
          Espace Client BPER
        </a>
        
        <a href="/"><i data-lucide="home"></i> Accueil</a>
        <a href="/jouer"><i data-lucide="dice-6"></i> Jouer</a>
        <a href="/jeu/mes-participations"><i data-lucide="ticket"></i> Mes tickets</a>
        <a href="/jeu/resultats"><i data-lucide="trophy"></i> Résultats</a>
        <a href="/paiement/retrait"><i data-lucide="banknote"></i> Retrait</a>
        <a href="/paiement/mes-retraits"><i data-lucide="arrow-up-circle"></i> Mes retraits</a>
        <a href="/paiement/recharger"><i data-lucide="credit-card"></i> Recharger</a>
        <a href="/paiement/mes-recharges"><i data-lucide="history"></i> Mes recharges</a>
        <a href="/contact"><i data-lucide="mail"></i> Contact</a>
        <a href="/profil"><i data-lucide="user"></i> Mon Profil</a>
        <a href="/paiement/solde"><i data-lucide="wallet"></i> Mon Solde</a>
        <a href="/auth/logout"><i data-lucide="log-out"></i> Déconnexion</a>
      <% } else { %>
        <a href="/"><i data-lucide="home"></i> Accueil</a>
        <a href="/jouer"><i data-lucide="dice-6"></i> Jouer</a>
        <a href="/jeu/resultats"><i data-lucide="trophy"></i> Résultats</a>
        <a href="/auth/login"><i data-lucide="log-in"></i> Connexion</a>
      <% } %>
    </div>
  </header>

  <main><%- body %></main>

  <script>
    // Gestion du menu hamburger
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('open');
      mobileMenu.classList.toggle('open');
    });

    // Active les icônes Lucide
    lucide.createIcons();

    // Gestion du Loader
    window.addEventListener('load', () => {
      document.body.classList.add('loaded');
      setTimeout(() => {
        const l = document.getElementById('loader');
        if (l && l.parentNode) l.parentNode.removeChild(l);
      }, 600);
    });

    // Fallback loader
    setTimeout(() => {
      if (!document.body.classList.contains('loaded')) {
        document.body.classList.add('loaded');
        const l = document.getElementById('loader');
        if (l && l.parentNode) l.parentNode.removeChild(l);
      }
    }, 5000);
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // On vérifie si l'URL contient un paramètre indiquant une déconnexion récente
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.has('loggedout') || document.referrer.includes('/auth/logout')) {
        
        // On cible les boutons BPER (desktop et mobile)
        const bperBtnDesktop = document.getElementById('bperBtnDesktop');
        const bperBtnMobile = document.getElementById('bperBtnMobile');
        
        // On ajoute la classe d'animation pulse si les boutons existent (l'utilisateur vient de se déconnecter)
        if (bperBtnDesktop) bperBtnDesktop.classList.add('animate-pulse');
        if (bperBtnMobile) bperBtnMobile.classList.add('animate-pulse');
        
        // Optionnel : Retirer l'animation après 10 secondes pour ne pas gêner
        setTimeout(() => {
          if (bperBtnDesktop) bperBtnDesktop.classList.remove('animate-pulse');
          if (bperBtnMobile) bperBtnMobile.classList.remove('animate-pulse');
        }, 10000);
      }
    });
  </script>

  <footer>
    <div class="footer-columns">
      <div class="footer-col">
        <h4>Liens utiles</h4>
        <ul>
          <li><a href="/jeu-responsable">Jeu Responsable</a></li>
          <li><a href="/contact">Contactez-nous</a></li>
          <li><a href="/reglements">Règlements</a></li>
          <li><a href="/securite">Sécurité</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Infos</h4>
        <ul>
          <li><a href="/">Site officiel</a></li>
          <li><a href="/groupe">Groupe</a></li>
          <li><a href="/fondation">Fondation</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Jeux</h4>
        <ul>
          <li><a href="/jouer">jeux disponibles</a></li>
          <li><a href="/comment-jouer">Comment jouer</a></li>
          <li><a href="/jeu/resultats">les résultats</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Vie Privée</h4>
        <ul>
          <li><a href="/politique-confidentialite">Confidentialité</a></li>
          <li><a href="/conditions">Conditions</a></li>
          <li><a href="/cookies">Cookies</a></li>
          <% if(user){ %><li><a href="/auth/logout">Déconnexion</a></li><% } %>
        </ul>
      </div>
    </div>

    <div class="footer-accordeon">
      <div class="footer-acc-item">
        <button class="acc-btn">Liens utiles ▾</button>
        <ul class="acc-content">
          <li><a href="/jeu-responsable">Jeu Responsable</a></li>
          <li><a href="/contact">Contactez-nous</a></li>
          <li><a href="/reglements">Règlements</a></li>
        </ul>
      </div>
      <div class="footer-acc-item">
        <button class="acc-btn">Infos ▾</button>
        <ul class="acc-content">
          <li><a href="/">Site officiel</a></li>
          <li><a href="/groupe">Groupe</a></li>
        </ul>
      </div>
      <div class="footer-acc-item">
        <button class="acc-btn">Jeux ▾</button>
        <ul class="acc-content">
          <li><a href="/jouer">jeux disponibles</a></li>
          <li><a href="/jeu/resultats">Les résultats</a></li>
        </ul>
      </div>
    </div>
  </footer>

  <script>
    // Gestion des accordéons footer
    document.querySelectorAll(".acc-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const content = btn.nextElementSibling;
        const isVisible = content.style.display === "block";
        document.querySelectorAll(".acc-content").forEach(el => el.style.display = "none");
        content.style.display = isVisible ? "none" : "block";
      });
    });
  </script>

  <style>
    /* Styles footer */
    footer {
      background-color: #0e0038;
      padding: 40px 20px;
      margin-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .footer-columns { display: flex; justify-content: space-between; gap: 2rem; max-width: 1300px; margin: 0 auto; }
    .footer-col { flex: 1; }
    .footer-col h4 { margin-bottom: 1rem; color: #fecd1a; font-size: 1.1rem; }
    .footer-col ul { list-style: none; padding: 0; margin: 0; }
    .footer-col ul li { margin-bottom: 0.6rem; }
    .footer-col ul li a { text-decoration: none; color: rgba(255,255,255,0.8); transition: 0.3s; font-size: 0.9rem; }
    .footer-col ul li a:hover { color: #fff; }

    .footer-accordeon { display: none; }
    .acc-btn { background: none; border: none; color: #fecd1a; font-weight: bold; cursor: pointer; width: 100%; text-align: left; padding: 10px 0; font-size: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .acc-content { display: none; list-style: none; padding: 10px 0; margin: 0; }
    .acc-content li { padding: 5px 0; }
    .acc-content li a { text-decoration: none; color: rgba(255,255,255,0.8); font-size: 0.9rem; }

    @media(max-width:768px){
      .footer-columns { display: none; }
      .footer-accordeon { display: block; }
    }
  </style>

  <div id="scrollRoyal">
    <svg width="70" height="70" viewBox="0 0 70 70">
      <circle class="track" cx="35" cy="35" r="30" />
      <circle class="progress" cx="35" cy="35" r="30" />
    </svg>
  </div>

  <style>
    #scrollRoyal {
      position: fixed;
      right: 20px;
      bottom: 20px;
      z-index: 999;
      width: 45px;
      height: 45px;
      cursor: pointer;
      transform: rotate(-90deg);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s, visibility 0.4s, transform 0.2s linear;
    }
    #scrollRoyal.visible { opacity: 1; visibility: visible; }
    .track { fill: none; stroke: rgba(255, 255, 255, 0.1); stroke-width: 6; }
    .progress { fill: none; stroke: #f97316; stroke-width: 6; stroke-linecap: round; stroke-dasharray: 188.4; stroke-dashoffset: 188.4; filter: drop-shadow(0 0 5px #f97316); }
  </style>

  <script>
    // Gestion du bouton scroll to top
    const progressRing = document.querySelector('.progress');
    const scrollRoyal = document.getElementById('scrollRoyal');

    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const progress = scrollTop / docHeight;
      const offset = 188.4 - progress * 188.4;
      progressRing.style.strokeDashoffset = offset;
      
      if (scrollTop > 200) { scrollRoyal.classList.add('visible'); } 
      else { scrollRoyal.classList.remove('visible'); }
    });

    scrollRoyal.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>

</body>
</html>