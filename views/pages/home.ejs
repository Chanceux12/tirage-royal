  </div>
</section>

<style>
/* ==========================================================================
   STYLING PROFESSIONNEL SECTORIEL : BANQUE PARTENAIRE BPER BANCA
   ========================================================================== */
.partner-bank-section {
  width: 100%;
  padding: 50px 16px;
  background: radial-gradient(130% 100% at top left, #07091e 40%, #0d1b3e 100%);
  border-top: 1px solid rgba(0, 150, 136, 0.15);
  border-bottom: 1px solid rgba(0, 150, 136, 0.05);
  box-sizing: border-box;
}

.bank-container {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}

/* --- Bloc Texte & Contenu --- */
.bank-info-block {
  flex: 1;
  min-width: 0;
}

.bank-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(0, 150, 136, 0.1);
  border: 1px solid rgba(0, 150, 136, 0.25);
  color: #00bfa5;
  padding: 6px 14px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 20px;
}

.bank-badge .badge-dot {
  width: 7px;
  height: 7px;
  background-color: #00bfa5;
  border-radius: 50%;
  box-shadow: 0 0 8px #00bfa5;
}

.bank-info-block h2 {
  font-size: 2.2rem;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.25;
  margin: 0 0 16px 0;
}

.bank-info-block .highlight-bank {
  color: #009688;
  position: relative;
}

.bank-lead {
  font-size: 1.05rem;
  line-height: 1.6;
  color: #b0b8d4;
  margin-bottom: 25px;
}

/* Liste des garanties */
.bank-guarantees {
  list-style: none;
  padding: 0;
  margin: 0 0 30px 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.bank-guarantees li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.95rem;
  color: #e2e8f0;
  line-height: 1.4;
}

.bank-guarantees li svg {
  flex-shrink: 0;
  margin-top: 2px;
}

.bank-guarantees li strong {
  color: #009688;
}

/* Bouton Institutionnel */
.btn-bank-portal {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #009688;
  color: #ffffff;
  text-decoration: none;
  padding: 14px 28px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  transition: all 0.25s ease;
  box-shadow: 0 4px 15px rgba(0, 150, 136, 0.3);
}

.btn-bank-portal:hover {
  background: #00796b;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 150, 136, 0.45);
}

/* --- Bloc Visuel Carte de Crédit --- */
.bank-card-visual {
  flex: 0 0 380px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.credit-card-luxury {
  width: 100%;
  height: 220px;
  background: linear-gradient(135deg, #0a1424 0%, #172a45 50%, #060b13 100%);
  border-radius: 16px;
  padding: 24px;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.05);
  overflow: hidden;
}

/* Texture de fond de la carte */
.credit-card-luxury::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(circle at 80% 20%, rgba(0, 150, 136, 0.15) 0%, transparent 60%);
  z-index: 1;
}

.card-chip {
  width: 42px;
  height: 32px;
  background: linear-gradient(135deg, #fce0ad 0%, #dfac6c 100%);
  border-radius: 6px;
  position: relative;
  z-index: 2;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
}

.card-logo-text {
  position: absolute;
  top: 24px;
  right: 24px;
  color: #ffffff;
  font-weight: 800;
  font-size: 1.4rem;
  letter-spacing: 0.5px;
  z-index: 2;
}

.card-logo-text span {
  font-weight: 300;
  color: #009688;
}

.card-type-indicator {
  position: absolute;
  top: 54px;
  right: 24px;
  font-size: 0.65rem;
  color: rgba(255,255,255,0.4);
  letter-spacing: 2px;
  font-weight: 700;
  z-index: 2;
}

.card-number-mock {
  margin-top: 40px;
  font-size: 1.35rem;
  color: #ffffff;
  font-family: 'Courier New', Courier, monospace;
  letter-spacing: 3px;
  position: relative;
  z-index: 2;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.card-holder-layout {
  position: absolute;
  bottom: 24px;
  left: 24px;
  z-index: 2;
}

.holder-lbl {
  font-size: 0.6rem;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1px;
  margin-bottom: 2px;
}

.holder-name {
  color: #ffffff;
  font-weight: 600;
  font-size: 0.9rem;
  letter-spacing: 0.5px;
}

/* Indicateur système en direct */
.bank-sync-status {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8rem;
  color: #94a3b8;
}

.status-pulse {
  width: 8px;
  height: 8px;
  background-color: #2ecc71;
  border-radius: 50%;
  position: relative;
}

.status-pulse::after {
  content: '';
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background-color: #2ecc71;
  border-radius: 50%;
  animation: statusRipple 2s infinite ease-in-out;
}

@keyframes statusRipple {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* ==========================================================================
   📱 RESPONSIVE MEDIA QUERIES (VUES DESKTOP & MOBILE COUVERTES)
   ========================================================================== */
@media (max-width: 960px) {
  .bank-container {
    flex-direction: column;
    gap: 35px;
    text-align: center;
  }
  
  .bank-badge {
    justify-content: center;
  }
  
  .bank-guarantees li {
    text-align: left;
  }
  
  .bank-card-visual {
    width: 100%;
    max-width: 400px;
    flex: none;
  }
}

@media (max-width: 520px) {
  .partner-bank-section {
    padding: 35px 12px;
  }
  
  .bank-info-block h2 {
    font-size: 1.65rem;
  }
  
  .bank-lead {
    font-size: 0.95rem;
  }
  
  .btn-bank-portal {
    width: 100%;
    box-sizing: border-box;
    justify-content: center;
    padding: 12px 20px;
    font-size: 0.95rem;
  }
  
  .credit-card-luxury {
    width: 90%;          /* S'assure que la carte ne touche pas les bords physiques du téléphone */
    height: 210px;        /* Hauteur réduite pour un rendu mobile plus élégant */
    padding: 18px;        /* Réduit l'espace intérieur pour compenser la taille plus petite */
    margin-left: auto;    /* Centre la carte si width < 100% */
    margin-right: auto;
  }
  
  .card-logo-text {
    top: 18px; right: 18px;
    font-size: 1.2rem;
  }
  
  .card-type-indicator { top: 44px; right: 18px; }
  
  .card-number-mock {
    margin-top: 30px;
    font-size: 1.15rem;
  }
  
  .card-holder-layout { bottom: 18px; left: 18px; }
}
</style>


<section class="titre-jeux">
  <h2>Des Millions à Gagner</h2>
  <p>Avec nos Loteries</p>
</section>


<section id="jeux" class="jeux-grid">
  <% if (jeux && jeux.length > 0) { %>
    <% jeux.forEach(jeu => { %>
      <div class="carte-jeu">
        <div class="image-container">
          <div class="timer-overlay" data-date="<%= jeu.prochainTirage %>">
            ⏳ <span class="timer">Chargement...</span>
          </div>
          <img src="<%= jeu.image %>" alt="<%= jeu.nom || 'Jeu' %>">
          <div class="overlay-titre"><%= (jeu.nom || 'Jeu').toUpperCase() %></div>
        </div>
        <div class="infos">
          <p>📅 Tirage :
            <%= new Date(jeu.prochainTirage).toLocaleString('fr-FR', {
              dateStyle: 'short',
              timeStyle: 'short'
            }) %>
          </p>
          <p>🎟️ <%= (jeu.billetsRestants || 0).toLocaleString() %> billets restants</p>
          <p>📊 Statut : <strong><%= jeu.statut || 'En cours' %></strong></p>
           <div> <span class="label-recompense">Récompense</div>
          <p> <span class="gain"><%= (jeu.recompense || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %> €</span></p> 
          <a href="/jeu/<%= jeu.slug %>" class="jouer-btn">Jouer pour <%= jeu.montant %> €</a>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p style="text-align: center;">Aucun jeu avec tirage à venir pour le moment.</p>
  <% } %>
</section>     

<!-- ===================== SECTION : Tickets Gagnants ===================== -->
<section class="gagnants-section my-12 px-4">

  <style>

     .result-header {
  text-align: center;
  margin: 40px 0 30px;
}

.result-header h1 {
  font-size: 2rem;
  font-weight: 700;
  color: #fff; /* blanc */
  margin-bottom: 10px;
}

.result-header p {
  font-size: 1rem;
  color: rgba(255,255,255,0.8);
}


    .gagnants-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      max-width: 1200px;
