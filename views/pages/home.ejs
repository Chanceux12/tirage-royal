    <div class="bank-card-visual">
      <div class="credit-card-luxury">
        <div class="card-chip"></div>
        <div class="card-logo-text">BPER <span>Banca</span></div>
        <div class="card-type-indicator">PARTNER PREMIUM</div>
        <div class="card-number-mock">•••• •••• •••• 2026</div>
        <div class="card-holder-layout">
          <div class="holder-lbl">MEMBRE ACCRÉDITÉ</div>
          <div class="holder-name">TIRAGE ROYAL VIP</div>
        </div>
      </div>
      
      <div class="bank-sync-status">
        <span class="status-pulse"></span> Terminal API Banque connecté (Statut : Opérationnel)
      </div>
